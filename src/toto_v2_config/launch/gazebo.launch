<launch>
    <arg name="robot_name"         default="/"/> <!-- Change this for namespacing. -->
    <arg name="rviz"               default="false"/> <!-- Set to true to run rviz in parallel. -->
    <arg name="lite"               default="false" />  <!-- Set to true if you're using CHAMP lite version. Only useful for microcontrollers. -->
    <arg name="ros_control_file"   default="$(find toto_v2_config)/config/ros_control/ros_control.yaml" /> <!-- Path to ROS Control configurations. Do not touch. -->
    <arg name="gazebo_world"       default="$(find toto_v2_config)/worlds/outdoor.world" /> <!-- Path to Gazebo world you want to load. -->
    <arg name="gui"                default="true"/>
    <arg name="paused"             default="true"/>  <!-- Start paused so controllers can hold pose before physics runs. -->
    <arg name="world_init_x"       default="0.0" /> <!-- X Initial position of the robot in Gazebo World -->
    <arg name="world_init_y"       default="0.0" /> <!-- Y Initial position of the robot in Gazebo World -->
    <arg name="world_init_z"       default="0.45" /> <!-- Z Initial position of the robot in Gazebo World -->
    <arg name="world_init_heading" default="0.0" /> <!-- Initial heading of the robot in Gazebo World -->
    <arg name="auto_stand"         default="true"/> <!-- Publish an initial pose automatically -->
    <arg name="stand_pose"         default="sit"/> <!-- stand | low | sit -->

    <param name="use_sim_time" value="true" />
    <!-- Ensure namespaced robot_description exists for gazebo_ros_control when robot_name is set -->
    <param name="$(arg robot_name)/robot_description" textfile="$(find x30_urdf)/X30/urdf/X30.urdf" />

    <include file="$(find toto_v2_config)/launch/bringup.launch">
        <arg name="robot_name"             value="$(arg robot_name)"/>
        <arg name="gazebo"                 value="true"/>
        <arg name="lite"                   value="$(arg lite)"/>
        <arg name="rviz"                   value="$(arg rviz)"/>
        <arg name="joint_controller_topic" value="joint_group_position_controller/command"/>
        <arg name="hardware_connected"     value="false"/>
        <arg name="publish_foot_contacts"  value="false"/>
        <arg name="publish_joint_control"  value="false"/>
        <arg name="close_loop_odom"        value="true"/>
    </include>

    <include file="$(find champ_gazebo)/launch/gazebo.launch">
        <arg name="robot_name"         value="$(arg robot_name)"/>
        <arg name="lite"               value="$(arg lite)"/>
        <arg name="ros_control_file"   value="$(arg ros_control_file)"/>
        <arg name="gazebo_world"       value="$(arg gazebo_world)"/>
        <arg name="world_init_x"       value="$(arg world_init_x)" />
        <arg name="world_init_y"       value="$(arg world_init_y)" />
        <arg name="world_init_z"       value="$(arg world_init_z)" />
        <arg name="world_init_heading" value="$(arg world_init_heading)" />
        <arg name="gui"                value="$(arg gui)" />
        <arg name="paused"             value="$(arg paused)" />
    </include>    

    <node if="$(arg auto_stand)" pkg="toto_v2_config" type="auto_stand.py" name="auto_stand"
          output="screen" ns="$(arg robot_name)">
        <param name="pose" value="$(arg stand_pose)" />
        <param name="robot_name" value="$(arg robot_name)" />
        <param name="set_model_configuration" value="true" />
        <param name="hold_with_controller" value="false" />
    </node>
</launch>
