    <!-- Uprooted root ball — torn from ground with fallen tree -->
    <model name="root_ball_1">
      <static>1</static>
      <pose>4 -2 0.4 0.3 0.2 0</pose>
      <link name="link">
        <collision name="col"><geometry><sphere><radius>0.9</radius></sphere></geometry></collision>
        <visual name="vis">
          <geometry><sphere><radius>0.9</radius></sphere></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Dirt</name></script></material>
        </visual>
      </link>
    </model>

    <model name="root_ball_2">
      <static>1</static>
      <pose>-4 4.5 0.35 0.1 -0.3 0.8</pose>
      <link name="link">
        <collision name="col"><geometry><sphere><radius>0.8</radius></sphere></geometry></collision>
        <visual name="vis">
          <geometry><sphere><radius>0.8</radius></sphere></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Dirt</name></script></material>
        </visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════════════
         PHYSICS
    ═══════════════════════════════════════════════════ -->
    <physics type="ode">
      <real_time_update_rate>1000</real_time_update_rate>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <ode>
        <solver>
          <type>quick</type>
          <iters>50</iters>
          <sor>1.3</sor>
        </solver>
        <constraints>
          <cfm>0.0</cfm>
          <erp>0.2</erp>
          <contact_max_correcting_vel>100</contact_max_correcting_vel>
          <contact_surface_layer>0.001</contact_surface_layer>
        </constraints>
      </ode>
    </physics>

    <gravity>0 0 -9.8</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    <atmosphere type="adiabatic"/>

  </world>
</sdf>
