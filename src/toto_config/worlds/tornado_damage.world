      </link>
    </model>

    <model name="tree_nw_2">
      <static>1</static>
      <pose>-3 8 0.2 0 1.5707 2.7</pose>
      <link name="trunk">
        <collision name="col"><geometry><cylinder><radius>0.19</radius><length>5.5</length></cylinder></geometry></collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.19</radius><length>5.5</length></cylinder></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Wood</name></script></material>
        </visual>
      </link>
    </model>

    <model name="tree_nw_2_foliage">
      <static>1</static>
      <pose>-5.7 9.6 0.3 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><sphere><radius>1.4</radius></sphere></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Foliage</name></script></material>
        </visual>
      </link>
    </model>

    <model name="tree_nw_3">
      <static>1</static>
      <pose>-8 6 0.2 0 1.5707 2.2</pose>
      <link name="trunk">
        <collision name="col"><geometry><cylinder><radius>0.21</radius><length>6.5</length></cylinder></geometry></collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.21</radius><length>6.5</length></cylinder></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Wood</name></script></material>
        </visual>
      </link>
    </model>

    <!-- ── PATH CENTERLINE — trees fall NE (tornado travel direction) ── -->

    <model name="tree_path_1">
      <static>1</static>
      <pose>2 2 0.2 0 1.5707 0.785</pose>
      <link name="trunk">
        <collision name="col"><geometry><cylinder><radius>0.25</radius><length>7.0</length></cylinder></geometry></collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.25</radius><length>7.0</length></cylinder></geometry>
