    <model name="tree_inflow_2">
      <static>1</static>
      <pose>3 -10 0.2 0 1.5707 0.5</pose>
      <link name="trunk">
        <collision name="col"><geometry><cylinder><radius>0.18</radius><length>5.5</length></cylinder></geometry></collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.18</radius><length>5.5</length></cylinder></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Wood</name></script></material>
        </visual>
      </link>
    </model>

    <!-- A few still-standing trees at the outer edge of damage zone -->
    <model name="tree_standing_1">
      <static>1</static>
      <pose>15 10 0 0 0 0</pose>
      <link name="trunk">
        <collision name="col"><geometry><cylinder><radius>0.2</radius><length>7.0</length></cylinder></geometry></collision>
        <visual name="vis">
          <origin xyz="0 0 3.5" />
          <geometry><cylinder><radius>0.2</radius><length>7.0</length></cylinder></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Wood</name></script></material>
        </visual>
      </link>
    </model>

    <model name="tree_standing_2">
      <static>1</static>
      <pose>-14 -12 0 0 0 0.3</pose>
      <link name="trunk">
        <collision name="col"><geometry><cylinder><radius>0.22</radius><length>7.0</length></cylinder></geometry></collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.22</radius><length>7.0</length></cylinder></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Wood</name></script></material>
        </visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════════════
         DAMAGED HOUSE
         Single-storey wood-frame structure — roof collapsed,
         south and east walls blown out (SE flank damage).
         Remains of NW wall and interior partition standing.
    ═══════════════════════════════════════════════════ -->

    <!-- Foundation slab -->
    <model name="house_foundation">
      <static>1</static>
      <pose>-8 -3 0.05 0 0 0.3</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>8.0 6.0 0.1</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>8.0 6.0 0.1</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Grey</name></script></material>
        </visual>
      </link>
    </model>

    <!-- North wall — still standing -->
    <model name="house_wall_north">
      <static>1</static>
      <pose>-8 0.0 1.1 0 0 0.3</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>8.0 0.2 2.2</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>8.0 0.2 2.2</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/WoodFloor</name></script></material>
        </visual>
      </link>
    </model>

    <!-- West wall — mostly standing, damaged top -->
    <model name="house_wall_west">
      <static>1</static>
      <pose>-12.1 -3.0 0.9 0 0 0.3</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.2 6.0 1.8</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.2 6.0 1.8</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/WoodFloor</name></script></material>
        </visual>
      </link>
    </model>

    <!-- East wall — blown out, only lower section remains -->
    <model name="house_wall_east_stub">
      <static>1</static>
      <pose>-3.9 -3.0 0.4 0 0 0.3</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.2 6.0 0.8</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.2 6.0 0.8</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/WoodFloor</name></script></material>
        </visual>
      </link>
    </model>

    <!-- Roof section — collapsed inward, tilted -->
    <model name="house_roof_collapsed">
      <static>1</static>
      <pose>-8.5 -2.5 0.9 0.4 0.15 0.3</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>7.5 5.5 0.15</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>7.5 5.5 0.15</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/WoodFloor</name></script></material>
        </visual>
      </link>
    </model>

    <!-- Interior debris — wall sections blown out -->
    <model name="wall_chunk_1">
      <static>1</static>
