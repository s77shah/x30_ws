      <static>1</static>
      <pose>6.9 6.9 0.5 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><sphere><radius>1.8</radius></sphere></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Foliage</name></script></material>
        </visual>
      </link>
    </model>

    <model name="tree_path_2">
      <static>1</static>
      <pose>-2 -2 0.2 0 1.5707 0.9</pose>
      <link name="trunk">
        <collision name="col"><geometry><cylinder><radius>0.22</radius><length>6.0</length></cylinder></geometry></collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.22</radius><length>6.0</length></cylinder></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Wood</name></script></material>
        </visual>
      </link>
    </model>

    <!-- ── SW INFLOW — trees lean toward tornado (northward) ── -->

    <model name="tree_inflow_1">
      <static>1</static>
      <pose>-6 -8 0.2 0 1.5707 0.4</pose>
      <link name="trunk">
        <collision name="col"><geometry><cylinder><radius>0.2</radius><length>6.0</length></cylinder></geometry></collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.2</radius><length>6.0</length></cylinder></geometry>
