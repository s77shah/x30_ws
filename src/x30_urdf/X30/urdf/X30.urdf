<?xml version="1.0" encoding="utf-8" ?>
<robot name="X30">
    <link name="base_link">
        <inertial>
            <origin xyz="0.0 0.0 0.0" />
            <mass value="0.1" />
            <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4" />
        </inertial>
    </link>
    <link name="base_laser">
        <inertial>
            <origin xyz="0 0 0" />
            <mass value="0.01" />
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" />
            <geometry>
                <cylinder length="0.05" radius="0.03" />
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" />
            <geometry>
                <cylinder length="0.05" radius="0.03" />
            </geometry>
        </collision>
    </link>
    <joint name="base_to_laser" type="fixed">
        <parent link="base_link" />
        <child link="base_laser" />
        <origin xyz="0.2 0 0.25" rpy="0 0 0" />
    </joint>
    <gazebo reference="base_laser">
        <sensor type="ray" name="x30_laser">
            <pose>0 0 0 0 0 0</pose>
            <visualize>false</visualize>
            <update_rate>20</update_rate>
            <ray>
                <scan>
                    <horizontal>
                        <samples>720</samples>
                        <resolution>1</resolution>
                        <min_angle>-1.5708</min_angle>
                        <max_angle>1.5708</max_angle>
                    </horizontal>
                </scan>
                <range>
                    <min>0.1</min>
                    <max>12.0</max>
                    <resolution>0.01</resolution>
                </range>
            </ray>
            <plugin name="gazebo_ros_laser_x30" filename="libgazebo_ros_laser.so">
                <robotNamespace>/x30</robotNamespace>
                <topicName>/x30/scan</topicName>
                <!-- Use the unprefixed link name; robot_state_publisher will add x30/ -->
                <frameName>base_laser</frameName>
            </plugin>
        </sensor>
    </gazebo>
    <joint name="base_to_torso" type="fixed">
        <parent link="base_link" />
        <child link="TORSO" />
        <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>
    <link name="TORSO">
        <inertial>
            <origin xyz="-0.0029257 7.5034e-06 0.020095" rpy="0 0 0" />
            <mass value="30.7" />
            <inertia ixx="0.364306" ixy="0.00018421" ixz="0.00027469" iyy="0.597627" iyz="0.00026784" izz="0.757267" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://x30_urdf/X30/meshes/torso.stl" />
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.44 0.26 0.15" />
            </geometry>
        </collision>
    </link>
    <link name="FL_HIP">
        <inertial>
            <origin xyz="-0.0018591 -0.011377 0.00027039" rpy="0 0 0" />
            <mass value="1.43" />
            <inertia ixx="0.0014068" ixy="-1.8545e-05" ixz="2.7664e-06" iyy="0.0026782" iyz="2.1221e-06" izz="0.0015918" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://x30_urdf/X30/meshes/hip.stl" />
            </geometry>
        </visual>
    </link>
    <joint name="FL_HipX_joint" type="revolute">
        <origin xyz="0.291 0.08 0" rpy="0 0 0" />
        <parent link="TORSO" />
        <child link="FL_HIP" />
        <axis xyz="-1 0 0" />
        <dynamics damping="1" friction="0.03" />
        <limit lower="-0.323" upper="0.585" effort="84" velocity="17.5" />
    </joint>
