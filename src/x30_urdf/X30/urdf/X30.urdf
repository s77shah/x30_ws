<?xml version="1.0" encoding="utf-8" ?>
<robot name="X30">
    <link name="base_link">
        <inertial>
            <origin xyz="0.0 0.0 0.0" />
            <mass value="0.1" />
            <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4" />
        </inertial>
    </link>
    <!-- ================================================================
         SENSORS: 4x Livox Mid-360 LiDARs + Wide-angle Camera
         Layout matches real X30: front-up, front-down, rear-up, rear-down
         Each 3D LiDAR: 360 deg horizontal, ~60 deg vertical FOV, 30m range
         2D scan on front-up LiDAR for AMCL/move_base compatibility
         Topics:
           /x30/scan                   - 2D LaserScan  (nav stack / AMCL)
           /x30/lidar_front_up/points  - PointCloud    (3D, rtabmap/explore)
           /x30/lidar_front_down/points
           /x30/lidar_rear_up/points
           /x30/lidar_rear_down/points
           /x30/camera/image_raw       - RGB image
           /x30/camera/camera_info
         ================================================================ -->

    <!-- ── Front-upper LiDAR ── -->
    <link name="lidar_front_up">
        <inertial>
            <origin xyz="0 0 0" />
            <mass value="0.07" />
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" />
            <geometry><cylinder length="0.04" radius="0.025" /></geometry>
        </visual>
    </link>
    <joint name="base_to_lidar_front_up" type="fixed">
        <parent link="base_link" />
        <child link="lidar_front_up" />
        <!-- Front face of body, tilted upward to cover above-horizon forward -->
        <origin xyz="0.22 0 0.10" rpy="0 -0.3 0" />
    </joint>
    <gazebo reference="lidar_front_up">
        <!-- 3D block laser → PointCloud on /x30/lidar_front_up/points -->
        <sensor type="ray" name="lidar_front_up_3d">
            <pose>0 0 0 0 0 0</pose>
            <visualize>false</visualize>
            <update_rate>10</update_rate>
            <ray>
                <scan>
                    <horizontal>
                        <samples>360</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.14159</min_angle>
                        <max_angle>3.14159</max_angle>
                    </horizontal>
                    <vertical>
                        <samples>32</samples>
                        <resolution>1</resolution>
                        <min_angle>-0.26180</min_angle>
                        <max_angle>0.78540</max_angle>
                    </vertical>
                </scan>
                <range>
                    <min>0.1</min>
                    <max>30.0</max>
                    <resolution>0.01</resolution>
                </range>
                <noise><type>gaussian</type><mean>0.0</mean><stddev>0.01</stddev></noise>
            </ray>
            <plugin name="gazebo_ros_lidar_front_up" filename="libgazebo_ros_block_laser.so">
                <robotNamespace>/x30</robotNamespace>
                <topicName>lidar_front_up/points</topicName>
                <frameName>lidar_front_up</frameName>
            </plugin>
        </sensor>
        <!-- 2D scan slice from this LiDAR for AMCL / move_base -->
        <sensor type="ray" name="x30_scan_2d">
            <pose>0 0 0 0 0 0</pose>
            <visualize>false</visualize>
            <update_rate>20</update_rate>
            <ray>
                <scan>
                    <horizontal>
                        <samples>720</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.14159</min_angle>
                        <max_angle>3.14159</max_angle>
                    </horizontal>
                </scan>
                <range>
                    <min>0.1</min>
                    <max>30.0</max>
                    <resolution>0.01</resolution>
                </range>
            </ray>
            <plugin name="gazebo_ros_scan" filename="libgazebo_ros_laser.so">
                <robotNamespace>/x30</robotNamespace>
                <topicName>/x30/scan</topicName>
                <frameName>lidar_front_up</frameName>
            </plugin>
        </sensor>
    </gazebo>

    <!-- ── Front-lower LiDAR ── -->
    <link name="lidar_front_down">
        <inertial>
            <origin xyz="0 0 0" />
            <mass value="0.07" />
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" />
            <geometry><cylinder length="0.04" radius="0.025" /></geometry>
        </visual>
    </link>
    <joint name="base_to_lidar_front_down" type="fixed">
        <parent link="base_link" />
        <child link="lidar_front_down" />
        <!-- Front face, tilted downward for ground/obstacle coverage -->
        <origin xyz="0.22 0 0.01" rpy="0 0.5 0" />
    </joint>
    <gazebo reference="lidar_front_down">
        <sensor type="ray" name="lidar_front_down_3d">
            <pose>0 0 0 0 0 0</pose>
            <visualize>false</visualize>
            <update_rate>10</update_rate>
            <ray>
                <scan>
                    <horizontal>
                        <samples>360</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.14159</min_angle>
                        <max_angle>3.14159</max_angle>
                    </horizontal>
                    <vertical>
                        <samples>32</samples>
                        <resolution>1</resolution>
                        <min_angle>-0.78540</min_angle>
                        <max_angle>0.26180</max_angle>
                    </vertical>
                </scan>
                <range>
                    <min>0.1</min>
                    <max>30.0</max>
                    <resolution>0.01</resolution>
                </range>
                <noise><type>gaussian</type><mean>0.0</mean><stddev>0.01</stddev></noise>
            </ray>
            <plugin name="gazebo_ros_lidar_front_down" filename="libgazebo_ros_block_laser.so">
                <robotNamespace>/x30</robotNamespace>
                <topicName>lidar_front_down/points</topicName>
                <frameName>lidar_front_down</frameName>
            </plugin>
        </sensor>
    </gazebo>

    <!-- ── Rear-upper LiDAR ── -->
    <link name="lidar_rear_up">
        <inertial>
            <origin xyz="0 0 0" />
            <mass value="0.07" />
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" />
            <geometry><cylinder length="0.04" radius="0.025" /></geometry>
        </visual>
    </link>
    <joint name="base_to_lidar_rear_up" type="fixed">
        <parent link="base_link" />
        <child link="lidar_rear_up" />
        <!-- Rear face, tilted upward -->
        <origin xyz="-0.22 0 0.10" rpy="0 -0.3 3.14159" />
    </joint>
    <gazebo reference="lidar_rear_up">
        <sensor type="ray" name="lidar_rear_up_3d">
            <pose>0 0 0 0 0 0</pose>
            <visualize>false</visualize>
            <update_rate>10</update_rate>
            <ray>
                <scan>
                    <horizontal>
                        <samples>360</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.14159</min_angle>
                        <max_angle>3.14159</max_angle>
                    </horizontal>
                    <vertical>
                        <samples>32</samples>
                        <resolution>1</resolution>
                        <min_angle>-0.26180</min_angle>
                        <max_angle>0.78540</max_angle>
                    </vertical>
                </scan>
                <range>
                    <min>0.1</min>
                    <max>30.0</max>
                    <resolution>0.01</resolution>
                </range>
                <noise><type>gaussian</type><mean>0.0</mean><stddev>0.01</stddev></noise>
            </ray>
            <plugin name="gazebo_ros_lidar_rear_up" filename="libgazebo_ros_block_laser.so">
                <robotNamespace>/x30</robotNamespace>
                <topicName>lidar_rear_up/points</topicName>
                <frameName>lidar_rear_up</frameName>
            </plugin>
        </sensor>
    </gazebo>

    <!-- ── Rear-lower LiDAR ── -->
    <link name="lidar_rear_down">
        <inertial>
            <origin xyz="0 0 0" />
            <mass value="0.07" />
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" />
            <geometry><cylinder length="0.04" radius="0.025" /></geometry>
        </visual>
    </link>
    <joint name="base_to_lidar_rear_down" type="fixed">
        <parent link="base_link" />
        <child link="lidar_rear_down" />
        <!-- Rear face, tilted downward -->
        <origin xyz="-0.22 0 0.01" rpy="0 0.5 3.14159" />
    </joint>
    <gazebo reference="lidar_rear_down">
        <sensor type="ray" name="lidar_rear_down_3d">
            <pose>0 0 0 0 0 0</pose>
            <visualize>false</visualize>
            <update_rate>10</update_rate>
            <ray>
                <scan>
                    <horizontal>
                        <samples>360</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.14159</min_angle>
                        <max_angle>3.14159</max_angle>
                    </horizontal>
                    <vertical>
                        <samples>32</samples>
                        <resolution>1</resolution>
                        <min_angle>-0.78540</min_angle>
                        <max_angle>0.26180</max_angle>
                    </vertical>
                </scan>
                <range>
                    <min>0.1</min>
                    <max>30.0</max>
                    <resolution>0.01</resolution>
                </range>
                <noise><type>gaussian</type><mean>0.0</mean><stddev>0.01</stddev></noise>
            </ray>
            <plugin name="gazebo_ros_lidar_rear_down" filename="libgazebo_ros_block_laser.so">
                <robotNamespace>/x30</robotNamespace>
                <topicName>lidar_rear_down/points</topicName>
                <frameName>lidar_rear_down</frameName>
            </plugin>
        </sensor>
    </gazebo>

    <!-- ── Wide-angle Camera ── -->
    <link name="camera_front">
        <inertial>
            <origin xyz="0 0 0" />
            <mass value="0.05" />
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" />
            <geometry><box size="0.03 0.06 0.03" /></geometry>
        </visual>
    </link>
    <joint name="base_to_camera_front" type="fixed">
        <parent link="base_link" />
        <child link="camera_front" />
        <!-- Top-front of body, slight downward tilt -->
        <origin xyz="0.22 0 0.13" rpy="0 0.15 0" />
    </joint>
    <gazebo reference="camera_front">
        <sensor type="camera" name="camera_front_sensor">
            <update_rate>30.0</update_rate>
            <camera name="camera_front">
                <horizontal_fov>1.5708</horizontal_fov>
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.02</near>
                    <far>50</far>
                </clip>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.007</stddev>
                </noise>
            </camera>
            <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
                <robotNamespace>/x30</robotNamespace>
                <alwaysOn>true</alwaysOn>
                <updateRate>30.0</updateRate>
                <cameraName>camera</cameraName>
                <imageTopicName>image_raw</imageTopicName>
                <cameraInfoTopicName>camera_info</cameraInfoTopicName>
                <frameName>camera_front</frameName>
            </plugin>
        </sensor>
    </gazebo>
    <joint name="base_to_torso" type="fixed">
        <parent link="base_link" />
        <child link="TORSO" />
        <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>
    <link name="TORSO">
        <inertial>
            <origin xyz="-0.0029257 7.5034e-06 0.020095" rpy="0 0 0" />
            <mass value="30.7" />
            <inertia ixx="0.364306" ixy="0.00018421" ixz="0.00027469" iyy="0.597627" iyz="0.00026784" izz="0.757267" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://x30_urdf/X30/meshes/torso.stl" />
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.44 0.26 0.15" />
            </geometry>
        </collision>
    </link>
    <link name="FL_HIP">
        <inertial>
            <origin xyz="-0.0018591 -0.011377 0.00027039" rpy="0 0 0" />
            <mass value="1.43" />
            <inertia ixx="0.0014068" ixy="-1.8545e-05" ixz="2.7664e-06" iyy="0.0026782" iyz="2.1221e-06" izz="0.0015918" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://x30_urdf/X30/meshes/hip.stl" />
            </geometry>
        </visual>
    </link>
    <joint name="FL_HipX_joint" type="revolute">
        <origin xyz="0.291 0.08 0" rpy="0 0 0" />
        <parent link="TORSO" />
        <child link="FL_HIP" />
        <axis xyz="-1 0 0" />
        <dynamics damping="1" friction="0.03" />
        <limit lower="-0.323" upper="0.585" effort="84" velocity="17.5" />
    </joint>
    <link name="FL_THIGH">
        <inertial>
            <origin xyz="-0.0087581 -0.023554 -0.055162" rpy="0 0 0" />
            <mass value="4.0809" />
            <inertia ixx="0.012604" ixy="0.00020291" ixz="-0.00030875" iyy="0.0164" iyz="0.00036593" izz="0.0061084" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://x30_urdf/X30/meshes/l_thigh.stl" />
            </geometry>
        </visual>
        <collision>
            <origin xyz="-0.02 0 -0.13" />
            <geometry>
                <cylinder length="0.25" radius="0.04" />
            </geometry>
        </collision>
    </link>
    <joint name="FL_HipY_joint" type="revolute">
        <origin xyz="0 0.11675 0" rpy="0 0 0" />
        <parent link="FL_HIP" />
        <child link="FL_THIGH" />
        <axis xyz="0 -1 0" />
        <dynamics damping="1" friction="0.03" />
        <limit lower="-2.967" upper="0.262" effort="84" velocity="17.5" />
    </joint>
    <link name="FL_SHANK">
        <inertial>
            <origin xyz="0.014851 2.0685e-05 -0.12283" rpy="0 0 0" />
            <mass value="0.71386" />
            <inertia ixx="0.0093039" ixy="1.7693e-07" ixz="0.00034843" iyy="0.0096272" iyz="-3.7717e-06" izz="0.00041542" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://x30_urdf/X30/meshes/shank.stl" />
            </geometry>
        </visual>
        <collision>
            <origin rpy="0. -0.40 0." xyz="0.02 0 -0.046" />
            <geometry>
                <cylinder length="0.1" radius="0.025" />
            </geometry>
        </collision>
        <collision>
            <origin rpy="0. 0 0." xyz="0.045 0 -0.155" />
            <geometry>
                <cylinder length="0.12" radius="0.025" />
            </geometry>
        </collision>
        <collision>
            <origin rpy="0. 0.45 0." xyz="0.025 0 -0.246" />
            <geometry>
                <cylinder length="0.08" radius="0.022" />
            </geometry>
        </collision>
    </link>
    <joint name="FL_Knee_joint" type="revolute">
        <origin xyz="0 0 -0.30" rpy="0 0 0" />
        <parent link="FL_THIGH" />
        <child link="FL_SHANK" />
        <axis xyz="0 -1 0" />
        <dynamics damping="1" friction="0.03" />
        <limit lower="0.349" upper="2.531" effort="180" velocity="16.1" />
    </joint>

    <link name="FL_FOOT">
        <inertial>
            <mass value="0.06" />
            <inertia ixx="1.45e-5" ixy="0" ixz="0" iyy="3.4e-5" iyz="0" izz="4.45e-5" />
            <origin xyz="0 0 0" rpy="0 0 0" />
        </inertial>

        <collision name="fl_footpad_collision">
            <origin xyz= "0 0 -0.01" rpy="0 0 0"/>
            <geometry>
            <box size="0.08 0.05 0.02" />
            </geometry>
        </collision>

        <visual name= "fl_foot_visual">
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <sphere radius="0.03" />
            </geometry>
        </visual>
    </link>

    <gazebo reference="FL_FOOT">
        <mu1>3.0</mu1>
        <mu2>3.0</mu2>
        <kp>5e4</kp>
        <kd>50</kd>
        <maxVel>0.1</maxVel>
        <minDepth>0.002</minDepth>
    </gazebo>
 
    <joint name="FL_Ankle" type="fixed" dont_collapse="true">
        <origin xyz="0 0 -0.31" />
        <parent link="FL_SHANK" />
        <child link="FL_FOOT" />
    </joint>
    <link name="FR_HIP">
        <inertial>
            <origin xyz="-0.0018591 0.011377 -2.7675e-05" rpy="3.14159 0 0" />
            <mass value="1.43" />
            <inertia ixx="0.0014068" ixy="1.8545e-05" ixz="-4.1487e-06" iyy="0.0026782" iyz="7.0795e-06" izz="0.0015918" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://x30_urdf/X30/meshes/hip.stl" />
            </geometry>
        </visual>
    </link>
    <joint name="FR_HipX_joint" type="revolute">
        <origin xyz="0.291 -0.08 0" rpy="0 0 0" />
        <parent link="TORSO" />
        <child link="FR_HIP" />
        <axis xyz="-1 0 0" />
        <dynamics damping="1" friction="0.03" />
        <limit lower="-0.585" upper="0.323" effort="84" velocity="17.5" />
    </joint>
    <link name="FR_THIGH">
        <inertial>
            <origin xyz="-0.0087433 0.023551 -0.055154" rpy="0 0 0" />
            <mass value="4.0809" />
            <inertia ixx="0.012604" ixy="-0.00020374" ixz="-0.0003086" iyy="0.0164" iyz="-0.00036585" izz="0.0061086" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://x30_urdf/X30/meshes/r_thigh.stl" />
            </geometry>
        </visual>
        <collision>
            <origin xyz="-0.02 0 -0.13" />
            <geometry>
                <cylinder length="0.25" radius="0.04" />
            </geometry>
        </collision>
    </link>
    <joint name="FR_HipY_joint" type="revolute">
        <origin xyz="0 -0.11675 0" rpy="0 0 0" />
        <parent link="FR_HIP" />
        <child link="FR_THIGH" />
        <axis xyz="0 -1 0" />
        <dynamics damping="1" friction="0.03" />
        <limit lower="-2.967" upper="0.262" effort="84" velocity="17.5" />
    </joint>
    <link name="FR_SHANK">
        <inertial>
            <origin xyz="0.014851 2.0687e-05 -0.12283" rpy="0 0 0" />
            <mass value="0.71386" />
            <inertia ixx="0.0093039" ixy="1.7692e-07" ixz="0.00034843" iyy="0.0096272" iyz="-3.7714e-06" izz="0.00041542" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://x30_urdf/X30/meshes/shank.stl" />
            </geometry>
        </visual>
        <collision>
            <origin rpy="0. -0.40 0." xyz="0.02 0 -0.046" />
            <geometry>
                <cylinder length="0.1" radius="0.025" />
            </geometry>
        </collision>
        <collision>
            <origin rpy="0. 0 0." xyz="0.045 0 -0.155" />
            <geometry>
                <cylinder length="0.12" radius="0.025" />
            </geometry>
        </collision>
        <collision>
            <origin rpy="0. 0.45 0." xyz="0.025 0 -0.246" />
            <geometry>
                <cylinder length="0.08" radius="0.022" />
            </geometry>
        </collision>
    </link>
    <joint name="FR_Knee_joint" type="revolute">
        <origin xyz="0 0 -0.30" rpy="0 0 0" />
        <parent link="FR_THIGH" />
        <child link="FR_SHANK" />
        <axis xyz="0 -1 0" />
        <dynamics damping="1" friction="0.03" />
        <limit lower="0.349" upper="2.531" effort="180" velocity="16.1" />
    </joint>
    <link name="FR_FOOT">
        <inertial>
            <mass value="0.06" />
            <inertia ixx="1.45e-5" ixy="0" ixz="0" iyy="3.4e-5" iyz="0" izz="4.45e-5" />
            <origin xyz="0 0 0" rpy="0 0 0" />
        </inertial>

        <collision name="fr_footpad_collision">
            <origin xyz= "0 0 -0.01" rpy="0 0 0"/>
            <geometry>
            <box size="0.08 0.05 0.02" />
            </geometry>
        </collision>

        <visual name= "fr_foot_visual">
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <sphere radius="0.03" />
            </geometry>
        </visual>
    </link>

    <gazebo reference="fr_footpad_collision">
        <mu1>3.0</mu1>
        <mu2>3.0</mu2>
        <kp>5e4</kp>
        <kd>50</kd>
        <maxVel>0.1</maxVel>
        <minDepth>0.002</minDepth>
    </gazebo>

    <joint name="FR_Ankle" type="fixed" dont_collapse="true">
        <origin xyz="0 0 -0.31" />
        <parent link="FR_SHANK" />
        <child link="FR_FOOT" />
    </joint>
    <link name="HL_HIP">
        <inertial>
            <origin xyz="0.0018591 -0.011377 -2.7675e-05" rpy="0 3.14159 0" />
